# payapi-x402-server configuration

PORT=3402

# Upstream new-api instance
UPSTREAM_URL=http://localhost:3001
UPSTREAM_TOKEN=sk-your-new-api-system-token

# On-chain settlement
PAY_TO_ADDRESS=0xYourUSDCReceivingAddress
GAS_PRIVATE_KEY=0xYourGasWalletPrivateKey
CHAIN_ID=84532          # 84532 = Base Sepolia, 8453 = Base mainnet
# USDC_ADDRESS=          # optional, defaults to known address for CHAIN_ID
# RPC_URL=               # optional, defaults to public Base RPC

# Storage
DB_PATH=./payapi.db
ADMIN_TOKEN=change-this-admin-token

# Tuning
CACHE_TTL_SECS=300
SIG_TIMEOUT_SECS=120
UPSTREAM_TIMEOUT_SECS=300
SHUTDOWN_TIMEOUT_SECS=10
MAX_BODY_BYTES=4194304
MARKUP=1.0

# Comma-separated browser origins. Use a strict list in production.
ALLOWED_ORIGINS=*

# Set to true to skip real on-chain settlement (dev/testing)
# DRY_RUN=false
