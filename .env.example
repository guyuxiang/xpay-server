# xpay-server configuration

PORT=3402
# Optional URL path prefix, e.g. /payapi when serving the app at https://www.openshort.cloud/payapi
# BASE_URL=/payapi

# Upstream new-api instance
UPSTREAM_URL=http://localhost:3001
UPSTREAM_TOKEN=sk-your-new-api-system-token

# On-chain settlement.
# PAYMENT_CHAIN=evm uses EIP-3009 on Base. PAYMENT_CHAIN=solana uses SPL Token transferChecked.
PAYMENT_CHAIN=evm
PAY_TO_ADDRESS=0xYourUSDCReceivingAddress
GAS_PRIVATE_KEY=0xYourGasWalletPrivateKey
CHAIN_ID=84532          # 84532 = Base Sepolia, 8453 = Base mainnet
# USDC_ADDRESS=          # optional, defaults to known address for CHAIN_ID
# RPC_URL=               # optional, defaults to public Base RPC

# Solana mode example:
# PAYMENT_CHAIN=solana
# SOLANA_CLUSTER=devnet  # devnet or mainnet-beta
# SOLANA_CONFIRMATION=confirmed
# PAY_TO_ADDRESS=YourMerchantSolanaWalletAddress
# USDC_ADDRESS=YourSolanaUSDCMintAddress
# RPC_URL=https://api.devnet.solana.com

# Storage
DB_PATH=./xpay.db
ADMIN_TOKEN=change-this-admin-token

# Tuning
CACHE_TTL_SECS=300
SIG_TIMEOUT_SECS=120
UPSTREAM_TIMEOUT_SECS=300
SHUTDOWN_TIMEOUT_SECS=10
MAX_BODY_BYTES=4194304
MARKUP=1.0

# Comma-separated browser origins. Use a strict list in production.
ALLOWED_ORIGINS=*

# Set to true to skip real on-chain settlement (dev/testing)
# DRY_RUN=false
